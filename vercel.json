{
    "version": 2,
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.9.0",
            "includeFiles": "{public/build/**,public/uploads/**,public/robots.txt,public/sitemap.xml,public/favicon.ico}"
        }
    },
    "builds": [
        { "src": "public/build/**", "use": "@vercel/static" },
        { "src": "public/uploads/**", "use": "@vercel/static" },
        { "src": "public/robots.txt", "use": "@vercel/static" },
        { "src": "public/sitemap.xml", "use": "@vercel/static" },
        { "src": "public/favicon.ico", "use": "@vercel/static" }
    ],
    "routes": [
        { "src": "/build/(.*)", "dest": "/public/build/$1" },
        { "src": "/uploads/(.*)", "dest": "/public/uploads/$1" },
        { "src": "/(favicon\\.ico|robots\\.txt|sitemap\\.xml)", "dest": "/public/$1" },
        { "src": "/(.*)", "dest": "/api/index.php" }
    ],
    "env": {
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp/views",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr"
    }
}

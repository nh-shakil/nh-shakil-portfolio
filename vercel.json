{
    "version": 2,
    "installCommand": "npm install",
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "functions": {
        "vercel.php": {
            "runtime": "vercel-php@0.9.0",
            "includeFiles": "{config/vite-assets.php,config/**,app/**,bootstrap/**,routes/**,resources/**,database/portfolio.sqlite,storage/**,public/uploads/**}"
        }
    },
    "routes": [
        { "src": "/build/(.*)", "dest": "/build/$1" },
        { "src": "/uploads/(.*)", "dest": "/uploads/$1" },
        { "src": "/(favicon\\.ico|robots\\.txt|sitemap\\.xml)", "dest": "/$1" },
        { "src": "/(.*)", "dest": "/vercel.php" }
    ],
    "env": {
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp/views",
        "CACHE_STORE": "array",
        "SESSION_DRIVER": "cookie",
        "LOG_CHANNEL": "stderr",
        "APP_URL": "https://nhshakil.vercel.app",
        "DB_CONNECTION": "sqlite",
        "DB_DATABASE": "/tmp/portfolio.sqlite"
    }
}
